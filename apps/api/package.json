{
  "name": "@jejak/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @jejak/stellar-client build && pnpm --filter @jejak/config build && pnpm --filter @jejak/domain build && pnpm --filter @jejak/api-client build && tsc -p tsconfig.build.json",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx scripts/migrate.ts up",
    "db:migrate:test-project": "tsx scripts/migrate-test-project.ts",
    "db:migrations:check": "tsx scripts/check-migrations.ts",
    "db:rollback": "tsx scripts/migrate.ts down",
    "dev": "node --env-file-if-exists=../../.env --import tsx --watch src/server.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "openapi:lint": "redocly lint openapi/openapi.yaml --config redocly.yaml",
    "risk:worker": "node --env-file-if-exists=../../.env --import tsx src/risk-worker.ts",
    "start": "node --env-file-if-exists=../../.env dist/server.js",
    "test": "vitest run",
    "test:integration:supabase": "node scripts/run-supabase-integration.mjs",
    "test:integration:supabase-settlement-offers": "node scripts/run-settlement-offers-supabase-integration.mjs",
    "test:integration:supabase-anchor": "node scripts/run-anchor-supabase-integration.mjs",
    "test:integration:supabase-storage": "node scripts/run-supabase-storage-integration.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@jejak/stellar-client": "workspace:*",
    "@fastify/cors": "11.3.0",
    "@fastify/helmet": "13.1.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/instrumentation-http": "0.220.0",
    "@opentelemetry/sdk-metrics": "2.9.0",
    "@opentelemetry/sdk-node": "0.220.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@supabase/supabase-js": "2.110.5",
    "@stellar/stellar-sdk": "14.5.0",
    "drizzle-orm": "0.45.2",
    "fastify": "5.10.0",
    "jose": "6.2.3",
    "postgres": "3.4.9",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@jejak/config": "workspace:*",
    "@redocly/cli": "2.39.0",
    "@types/node": "24.13.3",
    "drizzle-kit": "0.31.10",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
