{
  "name": "@jejak/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "openapi:lint": "redocly lint openapi/openapi.yaml --config redocly.yaml",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "11.3.0",
    "@fastify/helmet": "13.1.0",
    "fastify": "5.10.0",
    "postgres": "3.4.9",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@jejak/config": "workspace:*",
    "@redocly/cli": "2.39.0",
    "@types/node": "24.13.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
