# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
APP_VERSION=0.0.0
PARTNER_MODE=SANDBOX
WEB_ORIGIN=http://localhost:3000

# Supabase/PostgreSQL (backend only; never expose these in NEXT_PUBLIC_* variables)
DATABASE_URL=
DATABASE_DIRECT_URL=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWT_ISSUER=
SUPABASE_JWKS_URL=
SUPABASE_STORAGE_EVIDENCE_BUCKET=jejak-evidence

# Evidence storage (signed uploads are fixed at two hours by Supabase)
EVIDENCE_STORAGE_MODE=IN_MEMORY
EVIDENCE_FINALIZATION_DEADLINE_SECONDS=900
EVIDENCE_DOWNLOAD_TTL_SECONDS=300
EVIDENCE_MAX_BYTES=10485760
EVIDENCE_ALLOWED_CONTENT_TYPES=application/pdf,image/jpeg,image/png
EVIDENCE_ABANDONED_AFTER_SECONDS=86400
EVIDENCE_CLEANUP_BATCH_SIZE=100
# Production-only: base64url-encoded random value containing at least 32 bytes
EVIDENCE_INTENT_SIGNING_KEY=

# Dedicated cloud integration project guard
SUPABASE_TEST_PROJECT_REF=
JEJAK_ALLOW_TEST_PROJECT_MUTATION=false

# OpenTelemetry is optional; no local collector is required
OTEL_ENABLED=false
OTEL_SERVICE_NAME=jejak-api
OTEL_EXPORTER_OTLP_ENDPOINT=
