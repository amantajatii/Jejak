# One .env at the repo root is shared by every app (apps/server, apps/web, scripts).
# Copy to .env and fill in. Anything marked optional can stay blank for the demo.

# --- Server ---
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
EVIDENCE_BUCKET=evidence
WEB_ORIGIN=http://localhost:3000
JEJAK_ADMIN_API_KEY=

# --- Consumer identity (email OTP + mock KYC/KYB) ---
# CONSUMER_IDENTITY_MODE=mock enables the hackathon KYC/KYB simulation endpoint.
# Set RESEND_API_KEY to the real key from Resend. Keep it server-side; never use
# NEXT_PUBLIC_RESEND_API_KEY. EMAIL_FROM must be a verified sender/domain in Resend.
CONSUMER_IDENTITY_MODE=mock
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# --- Stellar / Soroban (testnet) ---
STELLAR_RPC_URL=
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=
MOCK_TOKEN_CONTRACT_ID=
MOCK_PASSPORT_CONTRACT_ID=
TASK_BOARD_CONTRACT_ID=
VERIFIER_REGISTRY_CONTRACT_ID=
STAKE_VAULT_CONTRACT_ID=
CREDENTIAL_ISSUER_CONTRACT_ID=
REWARD_DISTRIBUTOR_CONTRACT_ID=
ORCHESTRATOR_SECRET_KEY_HEX=
CUSTODY_ENCRYPTION_KEY=
SANDBOX_PUBLIC_BASE_URL=

# --- Verifier economics (IDR) ---
VERIFIER_MIN_STAKE_IDR=200000
VERIFIER_TASK_LOCK_IDR=60000
VERIFIER_REWARD_IDR=20000
VERIFIER_REPUTATION_DELTA=10

# --- Web ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
