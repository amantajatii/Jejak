# One .env at the repo root is shared by every app and script.
# Copy to .env and fill optional secrets locally. Never commit .env.

# --- Runtime ---
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
APP_VERSION=0.0.0
PARTNER_MODE=SANDBOX
WEB_ORIGIN=http://localhost:3000
JEJAK_ADMIN_API_KEY=

# --- PostgreSQL / Supabase ---
DATABASE_URL=
DATABASE_DIRECT_URL=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWT_ISSUER=
SUPABASE_JWKS_URL=
SUPABASE_STORAGE_EVIDENCE_BUCKET=jejak-evidence
SUPABASE_TEST_PROJECT_REF=
JEJAK_ALLOW_TEST_PROJECT_MUTATION=false

# --- Evidence storage ---
EVIDENCE_BUCKET=evidence
EVIDENCE_STORAGE_MODE=IN_MEMORY
EVIDENCE_FINALIZATION_DEADLINE_SECONDS=900
EVIDENCE_DOWNLOAD_TTL_SECONDS=300
EVIDENCE_MAX_BYTES=10485760
EVIDENCE_ALLOWED_CONTENT_TYPES=application/pdf,image/jpeg,image/png
EVIDENCE_ABANDONED_AFTER_SECONDS=86400
EVIDENCE_CLEANUP_BATCH_SIZE=100
EVIDENCE_INTENT_SIGNING_KEY=

# --- Consumer identity (email OTP + mock KYC/KYB) ---
CONSUMER_IDENTITY_MODE=mock
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

