{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jejak.finance/schemas/api/operations/results.schema.json",
  "title": "OperationResults",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "InstitutionalInvitation": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "tenantId", "roles", "status", "expiresAt"],
      "properties": {
        "id": { "$ref": "../../common/identifiers.schema.json#/$defs/uuidV7" },
        "tenantId": { "$ref": "../../common/identifiers.schema.json#/$defs/uuidV7" },
        "roles": { "type": "array", "items": { "$ref": "../../enums/actor-role.schema.json" }, "uniqueItems": true },
        "status": { "enum": ["PENDING", "ACCEPTED", "REVOKED", "EXPIRED"] },
        "expiresAt": { "$ref": "../../common/timestamp.schema.json" }
      }
    },
    "InstitutionalInvitationPreview": {
      "type": "object", "additionalProperties": false,
      "required": ["tenantId", "tenantDisplayName", "roles", "expiresAt"],
      "properties": {
        "tenantId": { "$ref": "../../common/identifiers.schema.json#/$defs/uuidV7" },
        "tenantDisplayName": { "type": "string", "minLength": 1, "maxLength": 160 },
        "roles": { "type": "array", "items": { "$ref": "../../enums/actor-role.schema.json" }, "uniqueItems": true },
        "expiresAt": { "$ref": "../../common/timestamp.schema.json" }
      }
    },
    "AcceptedJob": {
      "type": "object", "additionalProperties": false,
      "required": ["jobId", "status"],
      "properties": {
        "jobId": { "$ref": "../../common/identifiers.schema.json#/$defs/uuidV7" },
        "status": { "type": "string", "enum": ["QUEUED", "PROCESSING", "COMPLETED", "FAILED"] }
      }
    },
    "PortfolioSummary": {
      "type": "object", "additionalProperties": false,
      "required": ["totalExposure", "outstandingPrincipal", "claimCount"],
      "properties": {
        "totalExposure": { "$ref": "../../common/money.schema.json" },
        "outstandingPrincipal": { "$ref": "../../common/money.schema.json" },
        "claimCount": { "type": "integer", "minimum": 0 }
      }
    },
    "AuditEvent": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "actorRole", "action", "occurredAt", "resourceType", "resourceId"],
      "properties": {
        "id": { "$ref": "../../common/identifiers.schema.json#/$defs/uuidV7" },
        "actorRole": { "$ref": "../../enums/actor-role.schema.json" },
        "action": { "type": "string", "minLength": 1, "maxLength": 128 },
        "occurredAt": { "$ref": "../../common/timestamp.schema.json" },
        "resourceType": { "type": "string", "minLength": 1, "maxLength": 64 },
        "resourceId": { "type": "string", "minLength": 1, "maxLength": 255 }
      }
    }
  }
}
