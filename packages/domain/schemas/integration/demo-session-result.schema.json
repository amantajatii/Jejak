{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jejak.finance/schemas/integration/demo-session-result.schema.json",
  "title": "DemoSessionResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["accessToken", "tokenType", "expiresAt", "actorId", "tenantId", "role"],
  "properties": {
    "accessToken": { "type": "string", "minLength": 32, "maxLength": 4096, "writeOnly": true },
    "tokenType": { "const": "Bearer" },
    "expiresAt": { "$ref": "../common/timestamp.schema.json" },
    "actorId": { "$ref": "../common/identifiers.schema.json#/$defs/uuidV7" },
    "tenantId": { "$ref": "../common/identifiers.schema.json#/$defs/uuidV7" },
    "role": { "$ref": "../enums/actor-role.schema.json" }
  }
}
