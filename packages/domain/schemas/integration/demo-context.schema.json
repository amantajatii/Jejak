{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jejak.finance/schemas/integration/demo-context.schema.json",
  "title": "DemoContext",
  "type": "object",
  "additionalProperties": false,
  "required": ["scenario", "tenantId", "claimId", "claimState", "chainMode", "actors", "resetAt", "version"],
  "properties": {
    "scenario": { "type": "string", "enum": ["HAPPY", "ADVERSE"] },
    "tenantId": { "$ref": "../common/identifiers.schema.json#/$defs/uuidV7" },
    "claimId": { "$ref": "../common/identifiers.schema.json#/$defs/uuidV7" },
    "claimState": { "$ref": "../enums/claim-state.schema.json" },
    "chainMode": { "type": "string", "enum": ["TESTNET", "DETERMINISTIC"] },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actorId", "role", "label"],
        "properties": {
          "actorId": { "$ref": "../common/identifiers.schema.json#/$defs/uuidV7" },
          "role": { "$ref": "../enums/actor-role.schema.json" },
          "label": { "type": "string", "minLength": 1, "maxLength": 80 }
        }
      }
    },
    "resetAt": { "$ref": "../common/timestamp.schema.json" },
    "version": { "type": "integer", "minimum": 1 }
  }
}
